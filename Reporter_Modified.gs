        <td style="padding:10px; border:1px solid #eee; background:#fafafa; text-align:left;">한국 기준금리</td>
        <td style="padding:10px; border:1px solid #eee; font-weight:bold;">${krRate}%</td>
        <td style="padding:10px; border:1px solid #eee; background:#fafafa; text-align:left;">미국 기준금리</td>
        <td style="padding:10px; border:1px solid #eee; font-weight:bold;">${usRate}%</td>
        <td style="padding:10px; border:1px solid #eee; background:#fafafa; text-align:left;">한미 금리차</td>
        <td style="padding:10px; border:1px solid #eee; font-weight:bold; color:${rateDiff < 0 ? 'red' : 'blue'};">${rateDiff}%p</td>
      </tr>
      <tr>
        <td style="padding:10px; border:1px solid #eee; background:#fafafa; text-align:left;">환율 (USD/KRW)</td>
        <td style="padding:10px; border:1px solid #eee; font-weight:bold;">${fxRate}원 <span style="font-size:11px;color:#888;">${fxArrow}${Math.abs(fxChange).toFixed(1)}</span></td>
        <td style="padding:10px; border:1px solid #eee; background:#fafafa; text-align:left;">순유동성</td>
        <td style="padding:10px; border:1px solid #eee; font-weight:bold;">$${Math.round(netLiq)} B <span style="font-size:11px;color:#888;">${liqArrow}${Math.round(Math.abs(liqChange))}</span></td>
        <td style="padding:10px; border:1px solid #eee; background:#fafafa; text-align:left;">VIX (공포)</td>
        <td style="padding:10px; border:1px solid #eee; font-weight:bold; color:${vix > 20 ? 'red' : 'black'};">${vix} <span style="font-size:11px;color:#888;">${vixArrow}${Math.abs(vixChange).toFixed(2)}</span></td>
      </tr>
      <tr>
        <td style="padding:10px; border:1px solid #eee; background:#fafafa; text-align:left;">TGA (정부잔고)</td>
        <td style="padding:10px; border:1px solid #eee;">$${Math.round(tga)} B</td>
        <td style="padding:10px; border:1px solid #eee; background:#fafafa; text-align:left;">RRP (역레포)</td>
        <td style="padding:10px; border:1px solid #eee;">$${Math.round(rrp)} B</td>
        <td style="padding:10px; border:1px solid #eee; background:#fafafa; text-align:left;">Fed 총자산</td>
        <td style="padding:10px; border:1px solid #eee;">$${fedAssets} B</td>
      </tr>
      <tr>
        <td style="padding:10px; border:1px solid #eee; background:#fafafa; text-align:left;">하이일드 실효금리</td>
        <td style="padding:10px; border:1px solid #eee;">${highYield}%</td>
        <td style="padding:10px; border:1px solid #eee; background:#fafafa; text-align:left;">미국 CPI (인플레)</td>
        <td style="padding:10px; border:1px solid #eee;">${cpi.toFixed(2)}%</td>
        <td style="padding:10px; border:1px solid #eee; background:#fafafa; text-align:left;">PCE 물가지수</td>
        <td style="padding:10px; border:1px solid #eee;">${pce.toFixed(2)}</td>
      </tr>
    </table>
  `;

  const formattedInsight = formatAiText(aiReport);

  return `
    <!DOCTYPE html>
    <html>
    <body style="font-family:'Apple SD Gothic Neo', sans-serif; background-color:#f4f6f8; padding:20px;">
      <div style="max-width: 800px; margin:0 auto; background:#ffffff; border:1px solid #dce0e4; border-radius: 8px; overflow:hidden;">
        
        ${dashboardHtml}

        <div style="padding:25px;">
          <div style="background:#e3f2fd; border:1px solid #bbdefb; padding:15px; border-radius:4px; margin-top:10px;">
            <div style="font-size:13px; color:#1565c0; font-weight:bold;">Quant Engine Status</div>
            <div style="font-size:14px; color:#333; margin-top:5px;">
              Python 파이프라인에서 도출된 최신 지표가 분석에 반영되었습니다.
            </div>
          </div>

          <h3 style="font-size:18px; color:#003366; border-bottom:2px solid #eee; padding-bottom:10px; margin-top:30px;">
            AI Analyst Insight
          </h3>
          <div style="font-size:15px; line-height:1.7; color:#333;">
            ${formattedInsight}
          </div>
        </div>
      </div>
    </body>
    </html>
  `;
}

// ==========================================
// [UTILITIES]
// ==========================================
function formatAiText(text) {
  if (!text) return "";
  let html = text;

  // 1. 구분선 처리
  html = html.replace(/^---$/gm, '<hr style="border:0; border-top:1px dashed #ccc; margin: 30px 0;">');

  // 2. 핵심 요약 / 섹션 헤더 처리 (A. 팩트체크 등)
  html = html.replace(/^\[핵심 요약\]/gm, '<div style="background:#fff3e0; border-left:4px solid #f57c00; padding:6px 10px; font-weight:800; color:#e65100; margin: 25px 0 10px 0; font-size:15px; display:inline-block; border-radius:2px;">📌 핵심 요약</div>');
  html = html.replace(/^([A-C]\. .*)/gm, '<h3 style="margin: 35px 0 12px 0; color: #003366; font-size: 17px; padding-bottom: 8px; border-bottom: 2px solid #e0e0e0;">$1</h3>');

  // 3. 형광펜 및 강조
  html = html.replace(/^### ?(.*)/gm, '<h4 style="margin: 25px 0 10px 0; color: #003366; font-size: 16px;">$1</h4>');
  html = html.replace(/^\*\* ?(.*)\*\*$/gm, '<h4 style="margin: 25px 0 10px 0; color: #003366; font-size: 16px;">$1</h4>');
  html = html.replace(/\[\[(.*?)\]\]/g, '<span style="background-color: #ffebee; color: #c62828; font-weight: bold; padding: 2px 4px; border-radius: 3px;">$1</span>');
  html = html.replace(/\(\((.*?)\)\)/g, '<span style="background-color: #e3f2fd; color: #1565c0; font-weight: bold; padding: 2px 4px; border-radius: 3px;">$1</span>');
  html = html.replace(/\*\*(.*?)\*\*/g, '<b style="color:#222; font-size:15.5px;">$1</b>');

  // 4. 리스트 아이템 여백 넓히기 (단락 구분 극대화)
  html = html.replace(/^\* (.*)/gm, '<div style="margin-top:15px; margin-bottom:15px; color:#444; line-height:1.7;">• $1</div>');
  html = html.replace(/^- (.*)/gm, '<div style="margin-top:15px; margin-bottom:15px; color:#444; line-height:1.7;">🔹 $1</div>');

  return html.replace(/\n/g, '<br>');
}

function sendEmailReport(subject, htmlBody) {
  MailApp.sendEmail({ to: CONFIG.EMAIL_RECIPIENT, subject: subject, htmlBody: htmlBody });
}
