function renderFullReportEmail(market, signals, aiReport, todayStr) {
  const fxSignal = signals.find(s => s.indicator === 'FX_HEDGE_RATIO') || {};
  const meta = fxSignal.metadata || {};

  // Extract macro values securely
  const getMacro = (ticker, isPrevious = false) => {
    if (!market || !market.macro) return 0;
    const items = market.macro.filter(m => m.ticker === ticker);
    if (items.length === 0) return 0;
    // IF isPrevious is true, try to get a value from about 5-7 days ago (or the oldest available in the limit if < 5)
    if (isPrevious && items.length > 1) {
      // items are sorted date desc. Find one that is at least a few days old, or just pick the last one.
      return parseFloat(items[Math.min(items.length - 1, 5)].value);
    }
    return parseFloat(items[0].value);
  };

  const getAssetPrice = (symbol) => {
    if (!market || !market.assets) return 0;
    const items = market.assets.filter(a => a.symbol === symbol);
    if (items.length === 0) return 0;
    return parseFloat(items[0].close_price);
  };
  
  const krRate = getMacro('KR_BASE_RATE') || 0;
  const usRate = getMacro('FEDFUNDS') || getMacro('DGS2') || 0;
  const rateDiff = (krRate - usRate).toFixed(2);

  const cpi = getMacro('CPALTT01USM657N') || 0;
  const pce = getMacro('PCEPI') || 0;

  // Asset Price Changes for AI Context
  const getAssetTrend = (symbol) => {
    if (!market || !market.assets) return { price: 0, changePct: 0 };
    const items = market.assets.filter(a => a.symbol === symbol);
    if (items.length < 2) return { price: items.length === 1 ? parseFloat(items[0].close_price) : 0, changePct: 0 };
    
    const curr = parseFloat(items[0].close_price);
    // Find the closest previous trading day (usually index 1 if sorted by date desc)
    const prev = parseFloat(items[1].close_price);
    const changePct = prev > 0 ? ((curr - prev) / prev) * 100 : 0;
    return { price: curr, changePct: changePct.toFixed(2) };
  };

  const btc = getAssetTrend('BTC-USD');
  const gold = getAssetTrend('GC=F');
  const sp500 = getAssetTrend('^GSPC');
  const kospi = getAssetTrend('KOSPI200');

  // Push these exact trends into the marketContext so AI doesn't hallucinate
  if (marketContext.recent_trends) {
    marketContext.recent_trends.asset_daily_changes = {
      "BTC (Bitcoin)": `${btc.changePct}%`,
      "Gold": `${gold.changePct}%`,
      "S&P 500": `${sp500.changePct}%`,
      "KOSPI 200": `${kospi.changePct}%`
    };
  }

  // 주가/자산 가격 (이메일 표기용)
  const btcPrice = btc.price;
  const goldPrice = gold.price;
  const sp500Price = sp500.price;

  // 환율
  const fxRate = getMacro('DEXKOUS') || 0;
  const fxPrev = getMacro('DEXKOUS', true) || fxRate;
  const fxChange = fxRate - fxPrev;
  const fxArrow = fxChange > 0 ? "🔺" : (fxChange < 0 ? "🔻" : "-");

  const vix = getMacro('VIXCLS') || 0;
  const vixPrev = getMacro('VIXCLS', true) || vix;
  const vixChange = vix - vixPrev;
  const vixArrow = vixChange > 0 ? "🔺" : (vixChange < 0 ? "🔻" : "-");

  const tgaRaw = getMacro('WTREGEN');
  const tga = tgaRaw ? (tgaRaw / 1000) : 0;
  const rrp = getMacro('RRPONTSYD');
  const fedAssetsRaw = getMacro('WALCL');
  const fedAssets = fedAssetsRaw ? Math.round(fedAssetsRaw / 1000) : 0;

  let netLiq = 0;
  if (fedAssets > 0) {
    netLiq = fedAssets - tga - rrp;
  }

  // Previous Liquidity
  const tgaPrevRaw = getMacro('WTREGEN', true);
  const tgaPrev = tgaPrevRaw ? (tgaPrevRaw / 1000) : 0;
  const rrpPrev = getMacro('RRPONTSYD', true);
  const fedAssetsPrevRaw = getMacro('WALCL', true);
  const fedAssetsPrev = fedAssetsPrevRaw ? Math.round(fedAssetsPrevRaw / 1000) : 0;
  let netLiqPrev = 0; if (fedAssetsPrev > 0) netLiqPrev = fedAssetsPrev - tgaPrev - rrpPrev;
  const liqChange = netLiq - netLiqPrev;
  const liqArrow = liqChange > 0 ? "🔺" : (liqChange < 0 ? "🔻" : "-");

  const highYield = getMacro('BAMLH0A0HYM2EY') || getMacro('BAMLH0A0HYM2') || 0;
  const finStress = getMacro('STLFSI3') || 0;
  const ted = getMacro('TEDRATE') || 0;

