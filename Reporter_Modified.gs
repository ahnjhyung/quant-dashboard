function getGeminiDeepInsight(market, signals, dateStr, trends) {
  // Extract RAG Context from the signals
  const ragSignal = signals.find(s => s.indicator === 'RAG_HISTORICAL_MATCH');
  const ragContext = (ragSignal && ragSignal.metadata && ragSignal.metadata.rag_context) 
                      ? ragSignal.metadata.rag_context 
                      : "최근 유사한 과거 사례 기록이 없습니다.";

  const marketContext = {
    date: dateStr,
    recent_news: (market.news || []).slice(0, 5).map(n => n.title), // [NEW] Top 5 News Headlines
    macro_indicators: market.macro,           // 기존 거시 지표
    asset_prices: market.assets,              // 추가: 주가 지수, 금, 비트코인 등 자산 데이터 전달
    recent_trends: trends, 
    python_engine_signals: signals,
    ai_memory_retrieval_rag: ragContext       // [NEW] 벡터 DB 검색을 통한 과거 유사 사례 (RAG)
  };

  const prompt = `
    당신의 이름은 'Quant Master'이며, 거시경제 지표와 금융 데이터를 해석해 주는 친절하고 전문적인 AI 퀀트 비서입니다.
    아래는 시스템이 수집한 오늘자 거시경제 지표, 최신 금융 뉴스, 자산 가격 데이터, 그리고 과거 가장 유사했던 시장 상황에 대한 데이터(ai_memory_retrieval_rag)입니다.
    독자가 현재 시장의 맥락을 이해하고, 각 지표들이 현재 장세에서 어떤 의미를 가지는지 쉽게 파악할 수 있도록 브리핑 리포트를 작성하세요.

    [SYSTEM_DATA]
    ${JSON.stringify(marketContext, null, 2)}

    [작성 규칙]
    1. 데이터 코드명(예: WTREGEN, VIXCLS)은 리포트에 절대 노출하지 마세요. (대신 'TGA(미 재무부 일반계정)', 'VIX(미국 S&P 500 변동성 지수)' 등으로 표기)
    2. 'ai_memory_retrieval_rag'라는 시스템 변수명이나 'RAG'라는 기계적인 단어를 절대 쓰지 마세요. 대신 "과거 OOOO년 O월의 유사한 데이터 패턴을 참고해보면~" 처럼 자연스럽고 전문적으로 녹여내세요.
    3. 종목 추천이나 구체적인 자산 매수/매도(비중 조절) 리딩은 하지 마세요. 대신 현재 수치가 '시장 심리나 유동성에 어떤 영향을 미치고 있는지' 해석해 주는 데 집중하세요.
    4. 문체는 단호하고 전문적인 보고서 톤(~함, ~임, ~결과임)을 유지하며, 글이 너무 늘어지지 않게 핵심만 짚어주세요.

    [분석의 핵심 (RAG 데이터 및 자산 간 상관관계 100% 활용)]
    - 🔥 **과거와의 입체적 비교 분석**: 현재 지표(VIX 18 등)가 겉보기에 평온해 보이더라도, 시스템이 굳이 최악의 폭락장(예: 2020년 3월, 2022년 6월)을 가장 유사한 과거로 매칭(RAG)했다면 그 이유를 파헤쳐야 합니다. 단순 수치 비교를 넘어, 직전 과거 대비 현재 방어막(유동성 등)이 얼마나 더 얇은지 저울질하세요.
    - 🔥 **자산 및 지표 간 상관관계(Correlation & Divergence) 분석**: 단순히 개별 지표를 나열하는 것은 하수입니다. "현재 달러가 약세인데, 비트코인과 금이 동반 상승(양의 상관관계)하고 있다" 혹은 "국채 금리가 오르는데 기술주가 안 빠진다(디커플링/발산 현상)" 같은 **시장 내 톱니바퀴들의 연결성**을 날카롭게 짚어내야 합니다. 자산군들의 움직임이 정상적인 베타(Beta)를 따르고 있는지, 아니면 뭔가 이상 조짐(Divergence)이 있는지를 반드시 짚어주세요.

    [출력 포맷 (반드시 아래 마크다운 양식을 사용할 것)]
    ## 데일리 퀀트 브리핑 (${dateStr})

    ---
    [핵심 요약]
    (현재 시스템이 감지한 유동성/변동성의 핵심 흐름과, 과거 유사 사례(RAG) 및 주요 뉴스를 종합한 오늘의 가장 중요한 관전 포인트를 3줄 이내로 압축)

    ---
    A. 자산 간 상관관계 및 디커플링 진단 (Correlation & Divergence)
    (뉴스 센티멘트 보도(recent_news)와 더불어 달러, 환율, 금리, 주식, 금 등 주요 자산들이 현재 **어떻게 서로 얽혀서 움직이고 있는지** 1~2문단으로 날카롭게 분석. 뉴스의 호재/악재가 실제 거시 자산 흐름과 동조화되는지 디커플링되는지 짚어줄 것)

    ---
    B. 리스크 점검 (과거 유사 사례 기반 비교점)
    (시스템이 찾아낸 과거 유사 국면(RAG)의 특징을 언급하고, 현재 수치와 직접 저울질하여 현재 시점의 숨겨진 리스크 크기나 기회를 '비교 분석'할 것. 과거보다 무엇은 낫고 무엇은 최악인지 명확히 서술)

    ---
    C. 주요 거시 지표 모니터링 가이드
    (현재 장세에서 주의 깊게 봐야 할 3~4개의 핵심 거시 지표(유동성, VIX, 스프레드 등)를 선정하여, "현재 이 지표가 과거 위기 당시와 비교해 OOO 수치인데, 이는 시장에 ~한 의미를 가진다" 형식으로 해설)
  `;

  try {
    var url = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=' + CONFIG.GEMINI_API_KEY;
    var payload = { "contents": [{ "parts": [{ "text": prompt }] }] };
    var res = UrlFetchApp.fetch(url, {
      method: "POST", contentType: "application/json", payload: JSON.stringify(payload), muteHttpExceptions: true
    });
    return JSON.parse(res.getContentText()).candidates[0].content.parts[0].text;
  } catch (e) { return "AI 분석에 실패했습니다. (API 오류)"; }
}

