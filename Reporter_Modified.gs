// ==========================================
// [MAIN FUNCTION] Triggered after Python execution
// ==========================================
function runDailyReporter() {
  console.log("--- 📢 [Reporter] Starting AI Briefing ---");
  const todayKR = Utilities.formatDate(new Date(), "Asia/Seoul", "yyyy-MM-dd");

  try {
    // 1. Fetch Latest Data from Supabase
    const marketData = fetchLatestDataFromSupabase();

    // 2. Fetch Latest Trading Signals generated by Python (e.g. Z-Score, FX limits)
    const strategySignals = fetchLatestSignalsFromSupabase();

    // 2.5 Extract Trends
    const getMacro = (ticker, isPrevious = false) => {
      if (!marketData || !marketData.macro) return 0;
      const items = marketData.macro.filter(m => m.ticker === ticker);
      if (items.length === 0) return 0;
      if (isPrevious && items.length > 1) return parseFloat(items[Math.min(items.length - 1, 5)].value);
      return parseFloat(items[0].value);
    };

    const fxRate = getMacro('DEXKOUS');
    const fxPrev = getMacro('DEXKOUS', true) || fxRate;
    const vix = getMacro('VIXCLS');
    const vixPrev = getMacro('VIXCLS', true) || vix;

    // Netliq
    const fedAssetsRaw = getMacro('WALCL');
    const tgaRaw = getMacro('WTREGEN');
    const rrp = getMacro('RRPONTSYD');

    const fedAssetsPrevRaw = getMacro('WALCL', true);
    const tgaPrevRaw = getMacro('WTREGEN', true);
    const rrpPrev = getMacro('RRPONTSYD', true);

    const netLiq = (fedAssetsRaw ? fedAssetsRaw / 1000 : 0) - (tgaRaw ? tgaRaw / 1000 : 0) - rrp;
    const netLiqPrev = (fedAssetsPrevRaw ? fedAssetsPrevRaw / 1000 : 0) - (tgaPrevRaw ? tgaPrevRaw / 1000 : 0) - rrpPrev;

    const trends = {
      fx_change: (fxRate - fxPrev).toFixed(1),
      vix_change: (vix - vixPrev).toFixed(2),
      net_liquidity_change_billions: (netLiq - netLiqPrev).toFixed(0)
    };

    // 3. Generate Deep Insight using Gemini AI 
    const aiInsightText = getGeminiDeepInsight(marketData, strategySignals, todayKR, trends);

    // 4. Render and Send Email
    const emailHtml = renderFullReportEmail(marketData, strategySignals, aiInsightText, todayKR);

    // Extract a headline or strategy mode from the signals mapping
    const stratMsg = (strategySignals.find(s => s.indicator === 'FX_HEDGE_RATIO') || {}).metadata?.strategy_msg || "Normal Strategy";
    const subject = `[AI Quant Report] ${todayKR} : ${stratMsg}`;

    sendEmailReport(subject, emailHtml);

    console.log("--- ✅ [Reporter] Finished successfully ---");
  } catch (e) {
    console.error("❌ Reporter Error: " + e.message);
  }
}

// ==========================================
// [SUPABASE FETCHING]
// ==========================================
function fetchLatestDataFromSupabase() {
  const headers = {
    "apikey": CONFIG.SB_KEY,
    "Authorization": "Bearer " + CONFIG.SB_KEY
  };

  let marketData = {
    assets: [],
    macro: [],
    news: []
  };

  try {
    // Fetch Assets
    const resAsset = UrlFetchApp.fetch(`${CONFIG.SB_URL}/rest/v1/asset_metrics?order=date.desc&limit=50`, { headers: headers, muteHttpExceptions: true });
    marketData.assets = JSON.parse(resAsset.getContentText());

    // Fetch Macro - Increased limit to 100 to catch all indicators which may update on different days
    const resMacro = UrlFetchApp.fetch(`${CONFIG.SB_URL}/rest/v1/macro_indicators?order=date.desc&limit=100`, { headers: headers, muteHttpExceptions: true });
    marketData.macro = JSON.parse(resMacro.getContentText());

    // Fetch News Sentiment
    const resNews = UrlFetchApp.fetch(`${CONFIG.SB_URL}/rest/v1/news_sentiment?order=date.desc&limit=20`, { headers: headers, muteHttpExceptions: true });
    marketData.news = JSON.parse(resNews.getContentText());
  } catch (e) {
    console.error("Failed to fetch market data:", e);
  }

  return marketData;
}

function fetchLatestSignalsFromSupabase() {
  const headers = {
    "apikey": CONFIG.SB_KEY,
    "Authorization": "Bearer " + CONFIG.SB_KEY
  };

  try {
    // We changed the Python engine to save signals in macro_indicators with ticker='FX_HEDGE_RATIO'
    const resFX = UrlFetchApp.fetch(`${CONFIG.SB_URL}/rest/v1/macro_indicators?ticker=eq.FX_HEDGE_RATIO&order=date.desc&limit=1`, { headers: headers, muteHttpExceptions: true });
    let fxData = JSON.parse(resFX.getContentText());

    // RAG context is now pushed to the news_sentiment table under symbol='RAG_CONTEXT'
    const resRAG = UrlFetchApp.fetch(`${CONFIG.SB_URL}/rest/v1/news_sentiment?symbol=eq.RAG_CONTEXT&order=date.desc&limit=1`, { headers: headers, muteHttpExceptions: true });
    let ragData = JSON.parse(resRAG.getContentText());

    let signals = [];

    if (fxData && fxData.length > 0) {
      signals.push({
        date: fxData[0].date,
        indicator: "FX_HEDGE_RATIO",
        value: fxData[0].value,
        metadata: {
          fx_rate: "N/A (Check Raw Data)",
          z_score: "N/A",
          strategy_msg: `Today's FX Hedge Ratio Target: ${fxData[0].value * 100}%`
        }
      });
    }

    if (ragData && ragData.length > 0) {
      signals.push({
        date: ragData[0].date,
        indicator: "RAG_HISTORICAL_MATCH",
        value: ragData[0].buzz_volume, // number of matches
        metadata: { rag_context: ragData[0].title || "과거 데이터베이스 매칭 결과가 없습니다." }
      });
    }

    return signals;
  } catch (e) {
    console.error("Failed to fetch signals:", e);
  }

  return [];
}

