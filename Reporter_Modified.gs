    </div>

    <table style="width:100%; border-collapse: collapse; font-size: 13px; border:1px solid #e0e0e0; margin-top:10px; text-align:center;">
      <tr style="background:#f8f9fa;">
        <td colspan="6" style="padding:12px; border-bottom:2px solid #003366; font-weight:bold; color:#003366; text-align:left;">
